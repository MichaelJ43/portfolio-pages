<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= HTML.escape @page_title %></title>
  <link rel="stylesheet" href="https://static.michaelj43.dev/v1/m43-tokens.css">
  <link rel="stylesheet" href="https://static.michaelj43.dev/v1/m43-shell.css">
  <link rel="stylesheet" href="https://static.michaelj43.dev/v1/m43-primitives.css">
  <link rel="stylesheet" href="styles.css">
</head>
<body class="m43 m43-page">
  <div data-m43-auth-header></div>
  <div class="m43-page__body m43">
  <header class="site-header m43-site-header">
    <h1><%= HTML.escape @page_title %></h1>
    <% if subtitle = @subtitle %>
      <p class="subheader"><%= HTML.escape subtitle %></p>
    <% end %>
    <p class="intro m43-intro"><%= HTML.escape @intro %></p>
    <% if !@links.empty? %>
      <nav class="links m43-nav" aria-label="Profiles">
        <% @links.each do |link| %>
          <% url = link.url.downcase %>
          <a class="profile-link" href="<%= HTML.escape link.url %>">
            <% if url.includes?("github.com") %>
              <svg class="profile-link__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M12 2C6.477 2 2 6.488 2 12.02c0 4.426 2.865 8.18 6.839 9.505.5.094.682-.217.682-.482 0-.236-.008-.866-.013-1.7-2.782.605-3.37-1.344-3.37-1.344-.455-1.16-1.11-1.47-1.11-1.47-.909-.621.068-.608.068-.608 1.004.07 1.532 1.033 1.532 1.033.893 1.53 2.341 1.087 2.91.832.091-.649.35-1.088.636-1.338-2.22-.252-4.555-1.113-4.555-4.954 0-1.093.39-1.987 1.029-2.688-.103-.253-.446-1.272.098-2.651 0 0 .84-.269 2.75 1.026A9.556 9.556 0 0 1 12 6.844c.85.004 1.705.115 2.504.337 1.909-1.295 2.748-1.026 2.748-1.026.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.85-2.339 4.7-4.566 4.947.359.31.678.92.678 1.855 0 1.338-.012 2.419-.012 2.748 0 .268.18.58.688.481A10.021 10.021 0 0 0 22 12.02C22 6.488 17.522 2 12 2Z"></path>
              </svg>
            <% elsif url.includes?("linkedin.com") %>
              <svg class="profile-link__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M20.447 20.452H16.89V14.87c0-1.332-.025-3.047-1.857-3.047-1.86 0-2.145 1.453-2.145 2.949v5.68H9.33V9h3.414v1.561h.049c.476-.9 1.637-1.85 3.37-1.85 3.602 0 4.266 2.37 4.266 5.455v6.286zM5.337 7.433a2.065 2.065 0 1 1 0-4.13 2.065 2.065 0 0 1 0 4.13zM7.116 20.452H3.558V9h3.558v11.452z"></path>
              </svg>
            <% elsif url.starts_with?("mailto:") %>
              <svg class="profile-link__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M3 5h18a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Zm1.5 2.2v9.6h15V7.2l-7.5 5.25L4.5 7.2Zm.93-.2 6.57 4.6L18.57 7H5.43Z"></path>
              </svg>
            <% end %>
            <span><%= HTML.escape link.label %></span>
          </a>
        <% end %>
      </nav>
    <% end %>
  </header>

  <main class="m43-main">
    <section class="collapsible-section" aria-labelledby="site-tech-title">
      <details>
        <summary id="site-tech-title">How this website is built</summary>
        <p class="details-intro">Technical aspects demonstrated by the portfolio site itself.</p>
        <div class="info-grid">
          <% @site_technical_aspects.each do |aspect| %>
            <article>
              <h3><%= HTML.escape aspect.title %></h3>
              <p><%= HTML.escape aspect.description %></p>
            </article>
          <% end %>
        </div>
      </details>
    </section>

    <section class="collapsible-section skills-index-section" aria-labelledby="skills-title">
      <details>
        <summary id="skills-title">Skills</summary>
        <p class="details-intro">YAML-driven technical depth and workplace collaboration skills, grouped for quick scanning.</p>
        <div class="skill-index">
          <section class="skill-index__grouping" aria-labelledby="skills-technical-heading">
            <h3 class="skill-index__grouping-title" id="skills-technical-heading">Technical</h3>
            <% @skills.each do |group| %>
              <div class="skill-index__category">
                <h4 class="skill-index__category-title"><%= HTML.escape group.title %></h4>
                <ul class="inline-list inline-list--skills">
                  <% group.items.each do |item| %>
                    <li><%= HTML.escape item %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>
          </section>
          <section class="skill-index__grouping" aria-labelledby="skills-workplace-heading">
            <h3 class="skill-index__grouping-title" id="skills-workplace-heading">Workplace &amp; collaboration</h3>
            <% @workplace_skills.each do |group| %>
              <div class="skill-index__category">
                <h4 class="skill-index__category-title"><%= HTML.escape group.title %></h4>
                <ul class="inline-list inline-list--skills">
                  <% group.items.each do |item| %>
                    <li><%= HTML.escape item %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>
          </section>
        </div>
      </details>
    </section>

    <h2 class="section-title m43-section-title">Selected work</h2>
    <ul class="repo-list">
      <% @repos.each do |repo| %>
        <li class="repo-card">
          <h3 class="repo-card__title-row">
            <a class="repo-card__title-link" href="<%= HTML.escape repo.primary_url %>"><%= HTML.escape repo.primary_title %></a>
            <% if badge = repo.badge %>
              <% if href = badge.href %>
                <a class="repo-card__badge-link" href="<%= HTML.escape href %>">
                  <img class="repo-card__badge" src="<%= HTML.escape badge.src %>" alt="<%= HTML.escape badge.alt %>" loading="lazy" decoding="async">
                </a>
              <% else %>
                <img class="repo-card__badge" src="<%= HTML.escape badge.src %>" alt="<%= HTML.escape badge.alt %>" loading="lazy" decoding="async">
              <% end %>
            <% end %>
          </h3>
          <% if repo.github_sub_link? %>
            <p class="repo-link-row" aria-label="Source repository">
              <a href="<%= HTML.escape repo.url %>">GitHub</a>
            </p>
          <% end %>
          <p class="repo-meta">
            <span class="repo-name"><%= HTML.escape repo.repo %></span>
            <% repo.languages.first(4).each do |lang| %>
              <span class="lang"><%= HTML.escape lang %></span>
            <% end %>
          </p>
          <% if !repo.skills.empty? %>
            <ul class="skill-list" aria-label="Relevant skills for <%= HTML.escape repo.title %>">
              <% repo.skills.each do |skill| %>
                <li><%= HTML.escape skill %></li>
              <% end %>
            </ul>
          <% end %>
          <p class="summary"><%= HTML.escape repo.summary %></p>
        </li>
      <% end %>
    </ul>
  </main>

  <footer class="site-footer m43-site-footer">
    <p>Built with <a href="https://crystal-lang.org/">Crystal</a>. Source for this site lives alongside the generator in the same repository.</p>
  </footer>
  </div>

  <script
    src="https://static.michaelj43.dev/v1/m43-analytics.js"
    defer
    data-m43-app="portfolio-pages"
    data-m43-api="https://api.michaelj43.dev"
  ></script>
  <script
    src="https://static.michaelj43.dev/v1/m43-auth-header.js"
    defer
    data-m43-auth
    data-m43-api="https://api.michaelj43.dev"
    data-m43-auth-origin="https://auth.michaelj43.dev"
    data-m43-home-url="https://michaelj43.dev/"
    data-m43-nav-url="https://michaelj43.dev/navigation/"
    data-m43-nav-data-url="https://michaelj43.dev/navigation.json"
  ></script>
</body>
</html>
