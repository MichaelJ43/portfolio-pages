<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= HTML.escape @page_title %></title>
  <link rel="stylesheet" href="https://static.michaelj43.dev/v1/m43-tokens.css">
  <link rel="stylesheet" href="https://static.michaelj43.dev/v1/m43-shell.css">
  <link rel="stylesheet" href="https://static.michaelj43.dev/v1/m43-primitives.css">
  <link rel="stylesheet" href="../styles.css">
</head>
<body class="m43 m43-page">
  <div data-m43-auth-header></div>
  <div class="m43-page__body m43">
  <header class="site-header m43-site-header">
    <h1><%= HTML.escape @page_title %></h1>
    <p class="intro m43-intro"><%= HTML.escape @intro %></p>
    <% if !@links.empty? %>
      <%= Sitegen.profile_links_nav(@links) %>
    <% end %>
  </header>

  <main class="m43-main">
    <h2 class="section-title m43-section-title">Enterprise work</h2>
    <div class="corporate-list">
      <% @corporate_projects.each do |project| %>
        <article class="corporate-card">
          <div class="corporate-card__heading">
            <h3><%= HTML.escape project.company %></h3>
            <p><%= HTML.escape project.role %> · <%= HTML.escape project.period %></p>
          </div>
          <p class="summary"><%= HTML.escape project.summary %></p>
          <ul class="highlight-list">
            <% project.highlights.each do |highlight| %>
              <li><%= HTML.escape highlight %></li>
            <% end %>
          </ul>
          <% if !project.skills.empty? %>
            <ul class="skill-list" aria-label="Skills used at <%= HTML.escape project.company %>">
              <% project.skills.each do |skill| %>
                <li><%= HTML.escape skill %></li>
              <% end %>
            </ul>
          <% end %>
        </article>
      <% end %>
    </div>
  </main>

  <footer class="site-footer m43-site-footer">
    <p><a href="../navigation/">Back to navigation</a> · <a href="../">Portfolio home</a></p>
  </footer>
  </div>

  <script
    src="https://static.michaelj43.dev/v1/m43-analytics.js"
    defer
    data-m43-app="portfolio-pages"
    data-m43-api="https://api.michaelj43.dev"
  ></script>
  <script
    src="https://static.michaelj43.dev/v1/m43-auth-header.js"
    defer
    data-m43-auth
    data-m43-api="https://api.michaelj43.dev"
    data-m43-auth-origin="https://auth.michaelj43.dev"
    data-m43-home-url="https://michaelj43.dev/"
    data-m43-nav-url="https://michaelj43.dev/navigation/"
    data-m43-nav-data-url="https://michaelj43.dev/navigation.json"
  ></script>
</body>
</html>
